### REST Client Examples for PotionLab API
### Install the VS Code Extension: REST Client (humao.rest-client)
### Then right-click any request and select "Send Request"

@baseUrl = http://localhost:8000
@apiPrefix = /api/v1

# ============================================================================
# Health Check
# ============================================================================
GET {{baseUrl}}/health


# ============================================================================
# Flavor Tags CRUD
# ============================================================================

### Create Flavor Tag
# @name createFlavorTag
POST {{baseUrl}}{{apiPrefix}}/flavor-tags/
Content-Type: application/json

{
  "name": "Smoky",
  "category": "Profile"
}

### List Flavor Tags
GET {{baseUrl}}{{apiPrefix}}/flavor-tags/

### Get Flavor Tag Detail
# Replace 1 with an actual ID from the list
GET {{baseUrl}}{{apiPrefix}}/flavor-tags/1

### Update Flavor Tag
PUT {{baseUrl}}{{apiPrefix}}/flavor-tags/1
Content-Type: application/json

{
  "name": "Extra Smoky",
  "category": "Profile"
}

### Delete Flavor Tag
DELETE {{baseUrl}}{{apiPrefix}}/flavor-tags/1


# ============================================================================
# Ingredients CRUD
# ============================================================================

### Create Ingredient
# @name createIngredient
POST {{baseUrl}}{{apiPrefix}}/ingredients/
Content-Type: application/json

{
  "name": "Islay Scotch",
  "category": "Spirit",
  "description": "Peated single malt whisky from Islay",
  "flavor_tag_ids": [1]
}

### List Ingredients
GET {{baseUrl}}{{apiPrefix}}/ingredients/

### Get Ingredient Detail
GET {{baseUrl}}{{apiPrefix}}/ingredients/1

### Update Ingredient
PUT {{baseUrl}}{{apiPrefix}}/ingredients/1
Content-Type: application/json

{
  "name": "Laphroaig 10",
  "category": "Spirit",
  "description": "Very peaty Islay single malt",
  "flavor_tag_ids": [1]
}

### Delete Ingredient
DELETE {{baseUrl}}{{apiPrefix}}/ingredients/1


# ============================================================================
# Cocktails CRUD
# ============================================================================

### Create Cocktail
# @name createCocktail
POST {{baseUrl}}{{apiPrefix}}/cocktails/
Content-Type: application/json

{
  "name": "Smoky Martini",
  "description": "A dry martini with a peaty twist",
  "instructions": "Stir ingredients with ice and strain into a chilled glass.",
  "glass_type": "Martini",
  "difficulty": 2,
  "ingredients": [
    {
      "ingredient_id": 1,
      "amount": "60ml",
      "is_optional": false
    }
  ]
}

### List Cocktails
GET {{baseUrl}}{{apiPrefix}}/cocktails/

### Get Cocktail Detail
GET {{baseUrl}}{{apiPrefix}}/cocktails/1

### Update Cocktail
PUT {{baseUrl}}{{apiPrefix}}/cocktails/1
Content-Type: application/json

{
  "name": "The Peat Monster",
  "description": "Updated description",
  "instructions": "Shake vigorously and strain.",
  "glass_type": "Coupe",
  "difficulty": 3,
  "ingredients": [
    {
      "ingredient_id": 1,
      "amount": "50ml",
      "is_optional": false
    }
  ]
}

### Delete Cocktail
DELETE {{baseUrl}}{{apiPrefix}}/cocktails/1
