# PotionLab Environment Template
# Copy this file to .env and fill in your values
# Environment variables are prefixed with POTION_

# Database Configuration
# Default uses a local SQLite file in the data/ directory
# Create the directory first: mkdir -p data
POTION_DATABASE_URL=sqlite:///data/app.db

# Redis Configuration
# Used for caching API responses and idempotency tracking
POTION_REDIS_URL=redis://localhost:6379

# Application Settings
POTION_APP_TITLE=PotionLab
POTION_APP_VERSION=0.1.0
POTION_JWT_SECRET=change-me-in-production

# Streamlit API Connection
POTIONLAB_API_URL=http://localhost:8000

# Docker Compose Configuration
# PostgreSQL password (used by both db and api services)
# Only needed when running the Docker Compose stack
POSTGRES_PASSWORD=changeme_secure_password_here
